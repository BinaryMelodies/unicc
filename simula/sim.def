begin
	! This file is automatically generated;
@@{preamble}
@@for value, token in sorted(tokens.items()):
	integer @@{token.name.lstrip('_')} = @@{token.value};
@@end

	integer procedure yyparse@@{'(' + globals['yyparse_parameters'] + ')' if 'yyparse_parameters' in globals else ''};
@@if 'yyparse_parameter_declarations' in globals:
@@print(globals['yyparse_parameter_declarations'], file = file);
@@end
	begin
		@@{globals.get('yystype', 'ref(YYSTYPE)')} array value_stk(0:127);
		integer array state_stk(0:127);
		integer stk_pos;

		integer look_ahead;

		@@{globals.get('yystype', 'ref(YYSTYPE)')} yyval;
		integer current;

		procedure shift_state(state);
			value state;
			integer state;
		begin
			value_stk(stk_pos) :- yylval;
			stk_pos := stk_pos + 1;
			state_stk(stk_pos) := state;
			look_ahead := yylex@@{'(' + globals['yylex_arguments'] + ')' if 'yylex_arguments' in globals else ''};
			go to select
		end;

		procedure reduce(type);
			value type;
			integer type;
		begin
			current := type;
			go to shift
		end;

		procedure goto_state(state);
			value state;
			integer state;
		begin
			value_stk(stk_pos) :- yyval;
			stk_pos := stk_pos + 1;
			state_stk(stk_pos) := state
		end;

		stk_pos := 0;

		state_stk(0) := 0;
		look_ahead := yylex@@{'(' + globals['yylex_arguments'] + ')' if 'yylex_arguments' in globals else ''};

	select:
		begin
			switch select_state := @@{', '.join('state' + str(i) for i in range(len(states)))};
			go to select_state(state_stk(stk_pos) + 1);

@@for i, (state, table) in enumerate(zip(states, actions)):
		state@@{i}:
@@for index, item in enumerate(state.items):
			! @@{str(item).replace(';', 'semicolon')} ;
@@end
@@if len(table) == 1:
@@for token, (action, value) in sorted(table.items()):
@@if action == 'SHIFT':
			shift_state(@@{value})@@{';' if i != len(states) - 1 else ''}
@@elif action == 'APPLY':
			go to rule@@{value}@@{';' if i != len(states) - 1 else ''}
@@elif action == 'ERROR':
			yyerror("parse error");
			yyparse := 1;
			go to exit@@{';' if i != len(states) - 1 else ''}
@@continue
@@elif action == 'ACCEPT':
			yyparse := 0;
			go to exit@@{';' if i != len(states) - 1 else ''}
@@continue
@@end
@@end
@@else:
@@for index, (token, (action, value)) in enumerate(sorted(table.items(), key = lambda pair: (pair[0] == -1, *pair))):
@@if token == -1:
			else
@@else:
			@@{'if' if index == 0 else 'else if'} look_ahead = @@{token} then ! @@{repr(tokens[token] if token in tokens else chr(token)).replace(';', 'semicolon')} ;
@@end
@@if action == 'SHIFT':
				shift_state(@@{value})@@{';' if index == len(table) - 1 and i != len(states) - 1 else ''}
@@elif action == 'APPLY':
				go to rule@@{value}@@{';' if index == len(table) - 1 and i != len(states) - 1 else ''}
@@elif action == 'ERROR':
			begin
				yyerror("parse error");
				yyparse := 1;
				go to exit
			end@@{';' if index == len(table) - 1 and i != len(states) - 1 else ''}
@@elif action == 'ACCEPT':
			begin
				yyparse := 0;
				go to exit
			end@@{';' if index == len(table) - 1 and i != len(states) - 1 else ''}
@@end
@@end
@@end
@@end
		end;
@@for number, rule in enumerate(rules):
rule@@{number}:
		! @@{' '.join(map(repr, rule.tokens)).replace(';', 'semicolon') if len(rule.tokens) != 0 else '%empty'} ;
@@if len(rule.tokens) != 0:
		stk_pos := stk_pos - @@{len(rule.tokens)};
@@end
@@if rule.action != "":
		begin
@@{replace_placeholders(rule.action, 'yyval', 'value_stk(stk_pos+@@-1)')}
		end;
@@end
		reduce(@@{rule.production.value});
@@end
	shift:
		begin
			switch select_state := @@{', '.join('state' + str(i) for i in range(len(states)))};
			go to select_state(state_stk(stk_pos) + 1);
@@for i, (state, table) in enumerate(zip(states, gotos)):
		state@@{i}:
@@if len(table) == 0:
			go to select@@{';' if i != len(states) - 1 else ''}
@@continue
@@end
@@for index, item in enumerate(state.items):
			! @@{str(item).replace(';', 'semicolon')} ;
@@end
@@if len(table) == 1:
@@for token, entry in sorted(table.items()):
			goto_state(@@{entry});
			go to select@@{';' if i != len(states) - 1 else ''}
@@end
@@else:
@@for index, (token, entry) in enumerate(sorted(table.items(), key = lambda pair: (pair[0] == -1, *pair))):
@@if token == -1:
			else
@@else:
			@@{'if' if index == 0 else 'else if'} current = @@{token} then ! @@{repr(tokens[token] if token in tokens else chr(token)).replace(';', 'semicolon')} ;
@@end
			begin
				goto_state(@@{entry});
				go to select
			end@@{';' if index == len(table) - 1 else ''}
@@end
@@if -1 not in table:
			go to select@@{';' if i != len(states) - 1 else ''}
@@end
@@end
@@end
		end;
	exit:
	end;
@@{postamble}
end
