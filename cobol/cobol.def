      * This file is automatically generated
@@def print(text, file = None):
@@for line in text.split('\n'):
@@line = line.strip()
@@if line.startswith('*'):
@@line = '      ' + line
@@pass
@@else:
@@line = '       ' + line
@@end
@@while len(line) > 7:
@@continuation = ' '
@@index = line[:74].rfind(' ')
@@if len(line) <= 74:
@@index = 74
@@elif index <= 7:
@@index = 74
@@continuation = '-'
@@end
@@file.write(line[:index] + '\n')
@@line = '      ' + continuation + line[index:]
@@end
@@end
@@end
@@{preamble}
       01 ParsingData.
        02 ValueStk OCCURS 128 TIMES.
         @@{globals['yystype']}
        02 StateStk OCCURS 128 TIMES PIC 9(5).
        02 StkPos PIC 9(3) VALUE 1.
        02 CurrentNonTerminal PIC 9(5).
@@if max(len(rule.tokens) for rule in rules) > 0:
        02 YYValues OCCURS @@{max(len(rule.tokens) for rule in rules)} TIMES.
         @@{globals['yystype']}
@@end
        02 YYVal.
         @@{globals['yystype']}
        02 NextState PICTURE 9(10).
        02 Ctr PICTURE 9(3).
        02 Idx PICTURE 9(3).
@@for value, token in sorted(tokens.items()):
       77 T@@{token.name.replace('_', '')} PIC 9(5) VALUE @@{token.value}.
@@end
       PROCEDURE DIVISION.
        PERFORM MAIN.
        STOP RUN.

       YYParse SECTION.
        MOVE 1 TO StkPos.
        MOVE 0 TO StateStk(StkPos).
        PERFORM YYLex.

       YYParseSelect.
        EVALUATE StateStk(StkPos)
@@for i, (state, table) in enumerate(zip(states, actions)):
         WHEN @@{i}
@@for item in state.items:
      * @@{item}
@@end
@@if len(table) == 1:
@@for token, (action, value) in sorted(table.items()):
@@if action == 'SHIFT':
          MOVE @@{value} TO NextState
          GO TO YYParseShift
@@elif action == 'APPLY':
          GO TO YYParseRule@@{value}
@@elif action == 'ERROR':
          PERFORM YYError
          GO TO YYParseExit
@@continue
@@elif action == 'ACCEPT':
          GO TO YYParseExit
@@continue
@@end
@@end
@@else:
          EVALUATE TokenType
@@for token, (action, value) in sorted(table.items(), key = lambda pair: (pair[0] == -1, *pair)):
@@if token == -1:
           WHEN OTHER
@@else:
           WHEN @@{token} *> @@{tokens[token] if token in tokens else chr(token)!r}
      * @@{tokens[token] if token in tokens else chr(token)!r}
@@end
@@if action == 'SHIFT':
           MOVE @@{value} TO NextState
           GO TO YYParseShift
@@elif action == 'APPLY':
           GO TO YYParseRule@@{value}
@@elif action == 'ERROR':
           PERFORM YYError
           GO TO YYParseExit
@@continue
@@elif action == 'ACCEPT':
           GO TO YYParseExit
@@continue
@@end
@@end
          END-EVALUATE
@@end
@@end
         END-EVALUATE.

@@for number, rule in enumerate(rules):
       YYParseRule@@{number}.
      * @@{' '.join(map(repr, rule.tokens)) if len(rule.tokens) != 0 else '%empty'}
@@if len(rule.tokens) != 0:
         SUBTRACT @@{len(rule.tokens)} FROM StkPos.
         PERFORM VARYING Ctr FROM 1 BY 1 UNTIL Ctr > @@{len(rule.tokens)}
          COMPUTE Idx = StkPos + Ctr - 1
          MOVE ValueStk(Idx) TO YYValues(Ctr)
         END-PERFORM.
@@end
@@if rule.action != "":
         PERFORM
@@{replace_placeholders(rule.action, 'YYVal', 'YYValues(@@)')}
         END-PERFORM.
@@end
         MOVE @@{rule.production.value} TO CurrentNonTerminal.
         GO TO YYParseReduce.
@@end

       YYParseShift.
         MOVE TokenValue TO ValueStk(StkPos).
         ADD 1 TO StkPos.
         MOVE NextState TO StateStk(StkPos).
         PERFORM YYLex.
         GO TO YYParseSelect.

       YYParseReduce.
        EVALUATE StateStk(StkPos)
@@for i, (state, table) in enumerate(zip(states, gotos)):
@@if len(table) == 0:
@@continue
@@end
         WHEN @@{i}
@@for item in state.items:
       * @@{item}
@@end
@@if len(table) == 1:
@@for token, entry in sorted(table.items()):
          MOVE @@{entry} TO NextState
          GO TO YYParseGoTo
@@end
@@else:
          EVALUATE CurrentNonTerminal
@@for token, entry in sorted(table.items(), key = lambda pair: (pair[0] == -1, *pair)):
@@if token == -1:
           WHEN OTHER
@@else:
           WHEN @@{token} *> @@{tokens[token] if token in tokens else chr(token)!r}
@@end
            MOVE @@{entry} TO NextState
            GO TO YYParseGoTo
@@end
          END-EVALUATE
@@end
@@end
        END-EVALUATE.
        GO TO YYParseSelect.

       YYParseGoTo.
        MOVE YYVal TO ValueStk(StkPos).
        ADD 1 TO StkPos.
        MOVE NextState TO StateStk(StkPos).
        GO TO YYParseSelect.

       YYParseExit.
        EXIT.
@@{postamble}
