PROGRAM parse CONTEXT VOID
BEGIN
	# This file is automatically generated #
@@for index, (value, token) in enumerate(sorted(tokens.items())):
	INT @@{token.name.lower().lstrip('_')} := @@{token.value};
@@end
@@{preamble}

	PROC yyparse = @@{'(' + globals['yyparse_parameters'] + ')' if 'yyparse_parameters' in globals else ''}INT:
	BEGIN
		INT yyparse result;
		[128]@@{globals.get('yystype', 'YYSTYPE')} value stk;
		[128]INT state stk;
		INT stk pos := 0;

		INT look ahead;

		@@{globals.get('yystype', 'YYSTYPE')} yyval;
		INT current;

		PROC shift state = (INT state) VOID:
		BEGIN
			value stk[stk pos] := yylval;
			stk pos +:= 1;
			state stk[stk pos] := state;
			look ahead := yylex@@{'(' + globals['yylex_arguments'] + ')' if 'yylex_arguments' in globals else ''};
			GO TO select
		END;

		PROC reduce = (INT type) VOID:
		BEGIN
			current := type;
			GO TO shift
		END;

		PROC goto state = (INT state) VOID:
		BEGIN
			value stk[stk pos] := yyval;
			stk pos +:= 1;
			state stk[stk pos] := state
		END;

		state stk[0] := 0;
		look ahead := yylex@@{'(' + globals['yylex_arguments'] + ')' if 'yylex_arguments' in globals else ''};

	select:
		CASE state stk[stk pos] + 1 IN
@@for i, (state, table) in enumerate(zip(states, actions)):
			# @@{i} #
			BEGIN
@@for index, item in enumerate(state.items):
				# @@{str(item).replace('#', 'hash')} #
@@end
@@if len(table) == 1:
@@for token, (action, value) in sorted(table.items()):
@@if action == 'SHIFT':
				shift state(@@{value})
@@elif action == 'APPLY':
				GO TO rule@@{value}
@@elif action == 'ERROR':
				yyerror("parse error");
				yyparse result := 1;
				GO TO exit
@@continue
@@elif action == 'ACCEPT':
				yyparse result := 0;
				GO TO exit
@@continue
@@end
@@end
@@else:
@@case_list = sorted(pair for pair in table.items() if pair[0] != -1)
@@for index, (token, (action, value)) in enumerate(case_list):
				@@{'IF' if index == 0 else 'ELIF'} look ahead = @@{token} THEN # @@{repr(tokens[token] if token in tokens else chr(token)).replace('#', 'hash')} #
@@first_case = False
@@if action == 'SHIFT':
					shift state(@@{value})
@@elif action == 'APPLY':
					GO TO rule@@{value}
@@elif action == 'ERROR':
					yyerror("parse error");
					yyparse result := 1;
					go to exit
@@elif action == 'ACCEPT':
					yyparse result := 0;
					go to exit
@@end
@@end
@@if -1 in table:
@@(action, value) = table[-1]
				ELSE
@@if action == 'SHIFT':
					shift state(@@{value})
@@elif action == 'APPLY':
					GO TO rule@@{value}
@@elif action == 'ERROR':
					yyerror("parse error");
					yyparse result := 1;
					GO TO exit
@@elif action == 'ACCEPT':
					yyparse result := 0;
					GO TO exit
				end
@@end
@@end
				FI
@@end
			END@@{',' if i != len(states) - 1 else ''}
@@end
		ESAC;
@@for number, rule in enumerate(rules):
rule@@{number}:
		# @@{' '.join(map(repr, rule.tokens)).replace('#', 'hash') if len(rule.tokens) != 0 else '%empty'} #
@@if len(rule.tokens) != 0:
		stk pos := stk pos - @@{len(rule.tokens)};
@@end
@@if rule.action != "":
		BEGIN
@@{replace_placeholders(rule.action, 'yyval', 'value stk[stk pos+@@-1]')}
		END;
@@end
		reduce(@@{rule.production.value});
@@end
	shift:
		CASE state stk[stk pos] + 1 IN
@@for i, (state, table) in enumerate(zip(states, gotos)):
			# @@{i} #
			BEGIN
@@if len(table) == 0:
				GO TO select
			END@@{',' if i != len(states) - 1 else ''}
@@else:
@@for index, item in enumerate(state.items):
				# @@{str(item).replace('#', 'hash')} #
@@end
@@if len(table) == 1:
@@for token, entry in sorted(table.items()):
				goto state(@@{entry});
				GO TO select
			END@@{',' if i != len(states) - 1 else ''}
@@end
@@else:
@@first_case = True
@@case_list = sorted(pair for pair in table.items() if pair[0] != -1)
@@for index, (token, entry) in enumerate(case_list):
				@@{'IF' if index == 0 else 'ELIF'} current = @@{token} THEN # @@{repr(tokens[token] if token in tokens else chr(token)).replace('#', 'hash')} #
@@first_case = False
					goto state(@@{entry});
					GO TO select
@@end
@@if -1 in table:
@@entry = table[-1]
				ELSE
					goto state(@@{entry});
					go to select
				FI
@@else:
				FI;
				GO TO select
@@end
			END@@{',' if i != len(states) - 1 else ''}
@@end
@@end
@@end
		ESAC;
	exit:
		yyparse result
	END;
@@{postamble}
END
FINISH
