				return 1;
@@elif action == 'ACCEPT':
				return 0;
@@end
@@end
@@else:
				switch(look_ahead)
				{
@@for token, (action, value) in sorted(table.items()):
@@if token == -1:
				default:
@@else:
				case @@{token}: // @@{tokens[token] if token in tokens else chr(token)!r}
@@end
@@if action == 'SHIFT':
					value_stk[stk_pos] = yylval;
					stk_pos ++;
					state_stk[stk_pos] = @@{value};
					look_ahead = yylex(@@{globals.get('yylex_arguments', '')});
					break;
@@elif action == 'APPLY':
					apply_rule = @@{value};
					break;
@@elif action == 'ERROR':
					yyerror("parse error");
					return 1;
@@elif action == 'ACCEPT':
					return 0;
@@end
@@end
				}
				break;
@@end
@@end
			}
			switch(apply_rule)
			{
@@for number, rule in enumerate(rules):
			case @@{number}:
				// @@{' '.join(map(repr, rule.tokens)) if len(rule.tokens) != 0 else '%empty'}
@@if len(rule.tokens) != 0:
				stk_pos -= @@{len(rule.tokens)};
@@end
@@if rule.action != "":
				{
@@{replace_placeholders(rule.action, 'yyval', 'value_stk[stk_pos+@@-1]')}
				}
@@end
				current = @@{rule.production.value};
				break;
@@end

			}
			if(apply_rule == -1)
				continue;
			switch(state_stk[stk_pos])
			{
@@for i, (state, table) in enumerate(zip(states, gotos)):
@@if len(table) == 0:
@@continue
@@end
			case @@{i}:
@@for item in state.items:
				// @@{item}
@@end

@@if len(table) == 1:
@@for token, entry in sorted(table.items()):
				value_stk[stk_pos] = yyval;
				stk_pos ++;
				state_stk[stk_pos] = @@{entry};
				break;
@@end
@@else:
				switch(current)
				{
@@for token, entry in sorted(table.items()):
@@if token == -1:
				default:
@@else:
				case @@{token}: // @@{tokens[token] if token in tokens else chr(token)!r}
@@end
					value_stk[stk_pos] = yyval;
					stk_pos ++;
					state_stk[stk_pos] = @@{entry};
