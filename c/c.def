@@print("/* This file is automatically generated */", file = file)
@@{preamble}
enum
{
@@for value, token in sorted(tokens.items()):
	@@{token.name} = @@{token.value},
@@end
};
int yyparse(@@{globals.get('yyparse_parameters', 'void')})
{
	@@{globals.get('yystype', 'YYSTYPE')} value_stk[128];
	int state_stk[128];
	int stk_pos = 0;

	int look_ahead;

	@@{globals.get('yystype', 'YYSTYPE')} yyval;
	int current;

#define SHIFT(__state) \
	value_stk[stk_pos] = yylval; \
	stk_pos ++; \
	state_stk[stk_pos] = __state; \
	look_ahead = yylex(@@{globals.get('yylex_arguments', '')}); \
	goto select

#define REDUCE(__type) \
	current = __type; \
	goto shift

#define GOTO(__state) \
	value_stk[stk_pos] = yyval; \
	stk_pos ++; \
	state_stk[stk_pos] = __state

	state_stk[0] = 0;
	look_ahead = yylex(@@{globals.get('yylex_arguments', '')});

select:
	switch(state_stk[stk_pos])
	{
@@for i, (state, table) in enumerate(zip(states, actions)):
	case @@{i}:
@@for item in state.items:
		// @@{item}
@@end
@@if len(table) == 1:
@@for token, (action, value) in sorted(table.items()):
@@if action == 'SHIFT':
		SHIFT(@@{value});
@@elif action == 'APPLY':
		goto rule@@{value};
@@elif action == 'ERROR':
		yyerror("parse error");
		return 1;
@@continue
@@elif action == 'ACCEPT':
		return 0;
@@continue
@@end
@@end
@@else:
		switch(look_ahead)
		{
@@for token, (action, value) in sorted(table.items()):
@@if token == -1:
		default:
@@else:
		case @@{token}: // @@{tokens[token] if token in tokens else chr(token)!r}
@@end
@@if action == 'SHIFT':
			SHIFT(@@{value});
@@elif action == 'APPLY':
			goto rule@@{value};
@@elif action == 'ERROR':
			yyerror("parse error");
			return 1;
@@continue
@@elif action == 'ACCEPT':
			return 0;
@@continue
@@end
@@end
		}
@@end
		break;
@@end
	}
@@for number, rule in enumerate(rules):
rule@@{number}:
	// @@{' '.join(map(repr, rule.tokens)) if len(rule.tokens) != 0 else '%empty'}
@@if len(rule.tokens) != 0:
	stk_pos -= @@{len(rule.tokens)};
@@end
@@if rule.action != "":
	{
@@{replace_placeholders(rule.action, 'yyval', 'value_stk[stk_pos+@@-1]')}
	}
@@end
	REDUCE(@@{rule.production.value});
@@end
shift:
	switch(state_stk[stk_pos])
	{
@@for i, (state, table) in enumerate(zip(states, gotos)):
@@if len(table) == 0:
@@continue
@@end
	case @@{i}:
@@for item in state.items:
		// @@{item}
@@end
@@if len(table) == 1:
@@for token, entry in sorted(table.items()):
		GOTO(@@{entry});
		break;
@@end
@@else:
		switch(current)
		{
@@for token, entry in sorted(table.items()):
@@if token == -1:
		default:
@@else:
		case @@{token}: // @@{tokens[token] if token in tokens else chr(token)!r}
@@end
			GOTO(@@{entry});
			break;
@@end
		}
		break;
@@end
@@end
	}
	goto select;
}
@@{postamble}
