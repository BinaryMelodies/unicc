&& This file is automatically generated
@@{preamble}
@@for value, token in sorted(tokens.items()):
&&@@{token.name} = @@{token.value}
@@end

FUNCTION yyparse
@@if 'yyparse_parameter_declarations' in globals:
@@print(globals['yyparse_parameter_declarations'], file = file);
@@end
	DIMENSION state_stk(128)

	CREATE CURSOR value_stk (s c(16), i n(10))

	SELECT value_stk
	stk_pos = 1
	DO WHILE stk_pos <= 128
		APPEND BLANK
		stk_pos = stk_pos + 1
	ENDDO

	yyparse_result = 0
	stk_pos = 1
	state_stk(1) = 0
	look_ahead = yylex()

	DO WHILE .T.
		apply_rule = -1
		DO CASE
@@for i, (state, table) in enumerate(zip(states, actions)):
			CASE state_stk(stk_pos) = @@{i}
@@for item in state.items:
				&& @@{item}
@@end
@@if len(table) == 1:
@@for token, (action, value) in sorted(table.items()):
@@if action == 'SHIFT':
				&& value_stk(stk_pos) = yylval
				SELECT yylval
				SCATTER MEMVAR MEMO
				SELECT value_stk
				GOTO RECORD stk_pos
				GATHER MEMVAR MEMO
				stk_pos = stk_pos + 1
				state_stk(stk_pos) = @@{value}
				look_ahead = yylex()
@@elif action == 'APPLY':
				apply_rule = @@{value}
@@elif action == 'ERROR':
				DO yyerror WITH "parse error"
				yyparse_result = 1
				EXIT
@@continue
@@elif action == 'ACCEPT':
				yyparse_result = 0
				EXIT
@@continue
@@end
@@end
@@else:
				DO CASE
@@for i, (token, (action, value)) in enumerate(sorted(table.items(), key = lambda pair: (pair[0] < 0, pair[0]))):
@@if token != -1:
					CASE look_ahead = @@{token}
						&& @@{tokens[token] if token in tokens else chr(token)!r}
@@else:
					OTHERWISE
@@endif
@@if action == 'SHIFT':
						&& value_stk(stk_pos) = yylval
						SELECT yylval
						SCATTER MEMVAR MEMO
						SELECT value_stk
						GOTO RECORD stk_pos
						GATHER MEMVAR MEMO
						stk_pos = stk_pos + 1
						state_stk(stk_pos) = @@{value}
						look_ahead = yylex()
@@elif action == 'APPLY':
						apply_rule = @@{value}
@@elif action == 'ERROR':
						DO yyerror WITH "parse error"
						yyparse_result = 1
						EXIT
@@continue
@@elif action == 'ACCEPT':
						yyparse_result = 0
						EXIT
@@continue
@@end
@@end
				ENDCASE
@@end
@@end
		ENDCASE

		IF apply_rule <> -1
			DO CASE
@@for number, rule in enumerate(rules):
				CASE apply_rule = @@{number}
					&& @@{' '.join(map(repr, rule.tokens)) if len(rule.tokens) != 0 else '%empty'}
@@if len(rule.tokens) != 0:
					stk_pos = stk_pos - @@{len(rule.tokens)}
@@end
@@if rule.action != "":
@@for offset in range(len(rule.tokens)):
					CREATE CURSOR v@@{offset+1} (s c(16), i n(10))
					APPEND BLANK
					SELECT value_stk
					GOTO RECORD stk_pos+@@{offset+1}-1
					SCATTER MEMVAR MEMO
					SELECT v@@{offset+1}
					GATHER MEMVAR MEMO
@@end
@@if len(rule.tokens) > 0:
					SELECT v1
					SCATTER MEMVAR MEMO
@@end
@@{replace_placeholders(rule.action, '??', 'v@@').replace('??.', '')}
@@for offset in range(len(rule.tokens)):
					SELECT v@@{offset+1}
					USE
@@end
@@end
					current = @@{rule.production.value}
@@end
			ENDCASE
			DO CASE
@@for n, (i, state, table) in enumerate([(i, state, table) for (i, (state, table)) in enumerate(zip(states, gotos)) if len(table) != 0]):
				CASE state_stk(stk_pos) = @@{i}
@@for item in state.items:
					&& @@{item}
@@end
@@if len(table) == 1:
@@for token, entry in sorted(table.items()):
					SELECT value_stk
					GOTO RECORD stk_pos
					GATHER MEMVAR MEMO
					stk_pos = stk_pos + 1
					state_stk(stk_pos) = @@{entry}
@@end
@@else:
					DO CASE
					select case (current)
@@for i, (token, entry) in enumerate(sorted(table.items(), key = lambda pair: (pair[0] < 0, pair[0]))):
@@if token != -1:
						CASE current = @@{token}
							&& @@{tokens[token] if token in tokens else chr(token)!r}
@@else:
						OTHERWISE
@@end
							&& value_stk(stk_pos) = yyval
							&&SELECT yyval
							&&SCATTER MEMVAR MEMO
							SELECT value_stk
							GOTO RECORD stk_pos
							GATHER MEMVAR MEMO
							stk_pos = stk_pos + 1
							state_stk(stk_pos) = @@{entry}
@@end
					ENDCASE
@@end
@@end
			ENDCASE
		ENDIF
	ENDDO

	SELECT value_stk
	USE
	&&SELECT yyval
	&&USE
@@{postamble}
