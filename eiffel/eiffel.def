@@print("-- This file is automatically generated", file = file)
class
	@@{module_name.upper()}
@@{preamble}
feature {ANY}
@@for value, token in sorted(tokens.items()):
	@@{token.name.lower().lstrip('_')}: INTEGER
		once
			Result := @@{token.value}
		end
@@end

	yyparse: INTEGER
		local
			value_stk: ARRAY[like yylval]
			state_stk: ARRAY[INTEGER]
			stk_pos: INTEGER
			look_ahead: INTEGER
			yyval: like yylval
			current_nonterminal: INTEGER
			terminate: BOOLEAN
			apply_rule: INTEGER
		do
			create value_stk.make(1, 128)
			create state_stk.make(1, 128)
			stk_pos := 1
			yyval := Void
			current_nonterminal := 0
			terminate := False

			state_stk.put(0, 1)
			look_ahead := yylex

			from
			until
				terminate
			loop
				apply_rule := -1
				inspect
					state_stk@stk_pos
@@for i, (state, table) in enumerate(zip(states, actions)):
				when @@{i} then
@@for item in state.items:
					-- @@{item}
@@end
@@if len(table) == 1:
@@for token, (action, value) in sorted(table.items()):
@@if action == 'SHIFT':
					value_stk.put(yylval, stk_pos)
					stk_pos := stk_pos + 1
					state_stk.put(@@{value}, stk_pos)
					look_ahead := yylex
@@elif action == 'APPLY':
					apply_rule := @@{value}
@@elif action == 'ERROR':
					yyerror("parse error")
					Result := 1
					terminate := True
@@elif action == 'ACCEPT':
					Result := 0
					terminate := True
@@end
@@end
@@else:
					inspect
						look_ahead
@@for token, (action, value) in sorted(table.items(), key = lambda pair: (pair[0] == -1, *pair)):
@@if token == -1:
					else
@@else:
					when @@{token} then -- @@{tokens[token] if token in tokens else chr(token)!r}
@@end
@@if action == 'SHIFT':
						value_stk.put(yylval, stk_pos)
						stk_pos := stk_pos + 1
						state_stk.put(@@{value}, stk_pos)
						look_ahead := yylex
@@elif action == 'APPLY':
						apply_rule := @@{value}
@@elif action == 'ERROR':
						yyerror("parse error")
						Result := 1
						terminate := True
@@elif action == 'ACCEPT':
						Result := 0
						terminate := True
@@end
@@end
					end
@@end
@@end
				end
				if apply_rule /= -1 then
					inspect
						apply_rule
@@for number, rule in enumerate(rules):
					when @@{number} then
						-- @@{' '.join(map(repr, rule.tokens)) if len(rule.tokens) != 0 else '%empty'}
@@if len(rule.tokens) != 0:
						stk_pos := stk_pos - @@{len(rule.tokens)}
@@end
@@if rule.action != "":
						-- {
@@{replace_placeholders(rule.action, 'yyval', '(value_stk@(stk_pos+@@-1))')}
						-- }
@@end
						current_nonterminal := @@{rule.production.value}
@@end
					end
					inspect
						state_stk@stk_pos
@@for i, (state, table) in enumerate(zip(states, gotos)):
@@if len(table) == 0:
@@continue
@@end
					when @@{i} then
@@for item in state.items:
						-- @@{item}
@@end
@@if len(table) == 1:
@@for token, entry in sorted(table.items()):
						value_stk.put(yyval, stk_pos)
						stk_pos := stk_pos + 1
						state_stk.put(@@{entry}, stk_pos)
@@end
@@else:
						inspect
							current_nonterminal
@@for token, entry in sorted(table.items(), key = lambda pair: (pair[0], *pair)):
@@if token == -1:
						else
@@else:
						when @@{token} then -- @@{tokens[token] if token in tokens else chr(token)!r}
@@end
							value_stk.put(yyval, stk_pos)
							stk_pos := stk_pos + 1
							state_stk.put(@@{entry}, stk_pos)
@@end
						end
@@end
@@end
					end
				end
			end
		end
@@{postamble}
end
