@@print("-- This file is automatically generated", file = file)
@@{preamble}
@@if use_header is not None:
@@output_file = file
@@file = open(use_header, 'w')
@@print("-- This file is automatically generated", file = file)
package @@{module_name} is
@@end
	subtype TokenType is Integer range 0 .. @@{max(token for token in tokens.keys())};
@@for value, token in sorted(tokens.items()):
	@@{token.name.lstrip('_') if token.name != 'ACCEPT' else 'TOK_ACCEPT'} : constant TokenType := @@{token.value};
@@end
@@if use_header is not None:
	procedure YYParse(result : out Integer);
end @@{module_name};
@@file.close()
@@file = output_file
@@end
	procedure YYParse(result : out Integer) is
		value_stk : array(0 .. 127) of YYSTYPE;
		state_stk : array(0 .. 127) of Integer := (others => 0);
		stk_pos : Integer := 0;
		look_ahead : TokenType := 0;
		yyval : YYSTYPE;
		current : Integer := 0;
		apply_rule : Integer;

		procedure Shift(new_state : Integer) is
		begin
			value_stk(stk_pos) := yylval;
			stk_pos := stk_pos + 1;
			state_stk(stk_pos) := new_state;
			look_ahead := YYLex;
		end;

		procedure Go_To(new_state : Integer) is
		begin
			value_stk(stk_pos) := yyval;
			stk_pos := stk_pos + 1;
			state_stk(stk_pos) := new_state;
		end;

	begin
		look_ahead := YYLex;

		while True loop
			apply_rule := -1;
			case state_stk(stk_pos) is
@@for i, (state, table) in enumerate(zip(states, actions)):
				when @@{i} =>
@@for item in state.items:
					-- @@{item}
@@end
@@if len(table) == 1:
@@for token, (action, value) in sorted(table.items()):
@@if action == 'SHIFT':
					Shift(@@{value});
@@elif action == 'APPLY':
					apply_rule := @@{value};
@@elif action == 'ERROR':
					YYError("parse error");
					result := 1;
					return;
@@elif action == 'ACCEPT':
					result := 0;
					return;
@@end
@@end
@@else:
					case look_ahead is
@@for token, (action, value) in sorted(table.items(), key = lambda pair: (pair[0] == -1, *pair)):
@@if token == -1:
						when others =>
@@else:
						when @@{token} => -- @@{tokens[token] if token in tokens else chr(token)!r}
@@end
@@if action == 'SHIFT':
						Shift(@@{value});
@@elif action == 'APPLY':
						apply_rule := @@{value};
@@elif action == 'ERROR':
						YYError("parse error");
						result := 1;
						return;
@@elif action == 'ACCEPT':
						result := 0;
						return;
@@end
@@end
					end case;
@@end
@@end
				when others =>
					null; -- impossible
			end case;
			if apply_rule /= -1 then
				case apply_rule is
@@for number, rule in enumerate(rules):
					when @@{number} =>
						-- @@{' '.join(map(repr, rule.tokens)) if len(rule.tokens) != 0 else '%empty'}
@@if len(rule.tokens) != 0:
						stk_pos := stk_pos - @@{len(rule.tokens)};
@@end
@@if rule.action != "":
						begin
@@{replace_placeholders(rule.action, 'yyval', 'value_stk(stk_pos+@@-1)')}
						end;
@@end
						current := @@{rule.production.value};
@@end
					when others =>
						null; -- impossible
				end case;
				case state_stk(stk_pos) is
@@for i, (state, table) in enumerate(zip(states, gotos)):
@@if len(table) == 0:
@@continue
@@end
					when @@{i} =>
@@for item in state.items:
						-- @@{item}
@@end
@@if len(table) == 1:
@@for token, entry in sorted(table.items()):
						Go_To(@@{entry});
@@end
@@else:
						case current is
@@for token, entry in sorted(table.items(), key = lambda pair: (pair[0] == -1, *pair)):
@@if token == -1:
							when others =>
@@else:
							when @@{token} => -- @@{tokens[token] if token in tokens else chr(token)!r}
@@end
								Go_To(@@{entry});
@@end
@@if -1 not in table:
							when others =>
								null;
@@end
						end case;
@@end
@@end
					when others =>
						null;
				end case;
			end if;
		end loop;
	end YYParse;
@@{postamble}
