@@print("/* This file is automatically generated */", file = file)
@@{preamble}

use std::io::Read;

@@for value, token in sorted(tokens.items()):
const @@{token.name}: i32 = @@{token.value};
@@end

fn yyparse(@@{globals.get('yyparse_parameters', '')}) -> i32
{
	let mut value_stk: [@@{globals.get('yystype', 'YYSTYPE')}; 128] = [@@{globals.get('yyempty', 'YYEMPTY')}; 128];
	let mut state_stk: [i32; 128] = [0; 128];
	let mut stk_pos: usize = 0;
	let mut look_ahead: i32;
	let mut yylval: @@{globals.get('yystype', 'YYSTYPE')};
	let mut current: i32;

	state_stk[0] = 0;
	(look_ahead, yylval) = yylex(@@{globals.get('yylex_arguments', '')});

	loop
	{
		let mut apply_rule: i32 = -1;
		let mut yyval: @@{globals.get('yystype', 'YYSTYPE')} = @@{globals.get('yyempty', 'YYEMPTY')};

		match state_stk[stk_pos]
		{
@@for i, (state, table) in enumerate(zip(states, actions)):
		@@{i} =>
			{
@@for item in state.items:
				// @@{item}
@@end
@@if len(table) == 1:
@@for token, (action, value) in sorted(table.items()):
@@if action == 'SHIFT':
				value_stk[stk_pos] = yylval;
				stk_pos += 1;
				state_stk[stk_pos] = @@{value};
				(look_ahead, yylval) = yylex(@@{globals.get('yylex_arguments', '')});
@@elif action == 'APPLY':
				apply_rule = @@{value};
@@elif action == 'ERROR':
				yyerror("parse error");
				return 1;
@@elif action == 'ACCEPT':
				return 0;
@@end
@@end
@@else:
				match look_ahead
				{
@@for token, (action, value) in sorted(table.items()):
@@if token == -1:
@@continue
@@end
				@@{token} => // @@{tokens[token] if token in tokens else chr(token)!r}
					{
@@if action == 'SHIFT':
						value_stk[stk_pos] = yylval;
						stk_pos += 1;
						state_stk[stk_pos] = @@{value};
						(look_ahead, yylval) = yylex(@@{globals.get('yylex_arguments', '')});
@@elif action == 'APPLY':
						apply_rule = @@{value};
@@elif action == 'ERROR':
						yyerror("parse error");
						return 1;
@@elif action == 'ACCEPT':
						return 0;
@@end
					}
@@end
				_ =>
					{
@@if -1 in table:
@@(action, value) = table[-1]
@@if action == 'SHIFT':
						value_stk[stk_pos] = yylval;
						stk_pos += 1;
						state_stk[stk_pos] = @@{value};
						(look_ahead, yylval) = yylex(@@{globals.get('yylex_arguments', '')});
@@elif action == 'APPLY':
						apply_rule = @@{value};
@@elif action == 'ERROR':
						yyerror("parse error");
						return 1;
@@elif action == 'ACCEPT':
						return 0;
@@end
@@else:
						panic!();
@@end
					}
				}
@@end
			}
@@end
@@end
		_ =>
			panic!()
		}
		match apply_rule
		{
@@for number, rule in enumerate(rules):
		@@{number} =>
			{
				// @@{' '.join(map(repr, rule.tokens)) if len(rule.tokens) != 0 else '%empty'}
@@if len(rule.tokens) != 0:
				stk_pos -= @@{len(rule.tokens)};
@@end
@@if rule.action != "":
				{
@@{replace_placeholders(rule.action, 'yyval', 'value_stk[stk_pos+@@-1]')}
				}
@@end
				current = @@{rule.production.value};
			}
@@end
		-1 =>
			{
				continue;
			}
		_ =>
			panic!()
		}

		match state_stk[stk_pos]
		{
@@for i, (state, table) in enumerate(zip(states, gotos)):
@@if len(table) == 0:
@@continue
@@end
		@@{i} =>
			{
@@for item in state.items:
				// @@{item}
@@end

@@if len(table) == 1:
@@for token, entry in sorted(table.items()):
				value_stk[stk_pos] = yyval;
				stk_pos += 1;
				state_stk[stk_pos] = @@{entry};
@@end
@@else:
				match current
				{
@@for token, entry in sorted(table.items()):
@@if token == -1:
@@continue
@@end
					@@{token} => // @@{tokens[token] if token in tokens else chr(token)!r}
						{
							value_stk[stk_pos] = yyval;
							stk_pos += 1;
							state_stk[stk_pos] = @@{entry};
						}
@@end
@@if -1 in table:
@@entry = table[-1]
					_ =>
						{
							value_stk[stk_pos] = yyval;
							stk_pos += 1;
							state_stk[stk_pos] = @@{entry};
						}
@@else:
					_ => panic!()
@@end
				}
@@end
			}
@@end
		_ => ()
		}
	}
}

@@{postamble}
