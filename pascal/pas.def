@@print("(* This file is automatically generated *)", file = file)
@@{preamble}
@@for value, token in sorted(tokens.items()):
const @@{token.name} = @@{token.value};
@@end
function yyparse: integer;
	label done;
	var
		value_stk: array[0..127] of YYSTYPE;
		state_stk: array[0..127] of Integer;
		stk_pos: Integer;
		look_ahead: Integer;
		yyval: YYSTYPE;
		current: Integer;
		apply_rule: Integer;
		running: Boolean;

	procedure shift(state: Integer);
	begin
		value_stk[stk_pos] := yylval;
		stk_pos := stk_pos + 1;
		state_stk[stk_pos] := state;
		look_ahead := yylex
	end;

	procedure gotoState(state: Integer);
	begin
		value_stk[stk_pos] := yyval;
		stk_pos := stk_pos + 1;
		state_stk[stk_pos] := state
	end;
begin
	stk_pos := 0;

	state_stk[0] := 0;
	look_ahead := yylex;

	running := true;

	while running do
	begin
		apply_rule := -1;

		case state_stk[stk_pos] of
@@for i, (state, table) in enumerate(zip(states, actions)):
		@@{i}:
@@for item in state.items:
			{ @@{item} }
@@end
@@if len(table) == 1:
@@for token, (action, value) in sorted(table.items(), key = lambda pair: (pair[0] < 0, pair[0])):
@@if action == 'SHIFT':
			shift(@@{value});
@@elif action == 'APPLY':
			apply_rule := (@@{value});
@@elif action == 'ERROR':
			begin
				yyerror('parse error');
				yyparse := 1;
				running := false;
			end;
@@elif action == 'ACCEPT':
			begin
				yyparse := 0;
				running := false;
			end;
@@end
@@end
@@else:
			case look_ahead of
@@for token, (action, value) in sorted(table.items(), key = lambda pair: (pair[0] < 0, pair[0])):
@@if token == -1:
			else
@@else:
			@@{token}: { @@{tokens[token] if token in tokens else chr(token)!r} }
@@end
@@if action == 'SHIFT':
				shift(@@{value});
@@elif action == 'APPLY':
				apply_rule := (@@{value});
@@elif action == 'ERROR':
				begin
					yyerror('parse error');
					yyparse := 1;
					running := false;
				end;
@@elif action == 'ACCEPT':
				begin
					yyparse := 0;
					running := false;
				end;
@@end
@@end
			end;
@@end
@@end
		end;
		case apply_rule of
@@for number, rule in enumerate(rules):
		@@{number}:
			begin
				{ @@{' '.join(map(repr, rule.tokens)) if len(rule.tokens) != 0 else '%empty'} }
@@if len(rule.tokens) != 0:
				stk_pos := stk_pos - @@{len(rule.tokens)};
@@end
@@if rule.action != "":
				begin
@@{replace_placeholders(rule.action, 'yyval', 'value_stk[stk_pos+@@-1]')}
				end;
@@end
				current := @@{rule.production.value};
			end;
@@end
		end;
		if apply_rule = -1 then
			goto done;
		case state_stk[stk_pos] of
@@for i, (state, table) in enumerate(zip(states, gotos)):
@@if len(table) == 0:
@@continue
@@end
		@@{i}:
@@for item in state.items:
			{ @@{item} }
@@end
@@if len(table) == 1:
@@for token, entry in sorted(table.items(), key = lambda pair: (pair[1] < 0, pair[1])):
			gotoState(@@{entry});
@@end
@@else:
			case current of
@@for token, entry in sorted(table.items(), key = lambda pair: (pair[1] < 0, pair[1])):
@@if token == -1:
			else
@@else:
			@@{token}: { @@{tokens[token] if token in tokens else chr(token)!r} }
@@end
				gotoState(@@{entry});
@@end
			end;
@@end
@@end
		end;
	done:
	end
end;
@@{postamble}
