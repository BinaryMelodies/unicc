@@print("(* This file is automatically generated *)", file = file)
@@{preamble}
@@for value, token in sorted(tokens.items()):
	@@{token.name}: (# exit @@{token.value} #);
@@end
yyparse: (#
	value_stk: [128]^@@{globals.get('yystype', 'YYSTYPE')};
	state_stk: [128]@Integer;
	stk_pos: @Integer;
	look_ahead: @Integer;
	yyval: ^@@{globals.get('yystype', 'YYSTYPE')};
	current: @Integer;
	apply_rule: @Integer;
	result: @Integer;

	SHIFT: (#
		next_state: @Integer;
	enter next_state
	do
		yylval[] -> value_stk[stk_pos][];
		stk_pos + 1 -> stk_pos;
		next_state -> state_stk[stk_pos];
		yylex -> look_ahead
	#);

	REDUCE: (#
		type: @Integer;
	enter type
	do
		type -> current
	#);

	GOTO: (#
		next_state: @Integer;
	enter next_state
	do
		yyval[] -> value_stk[stk_pos][];
		stk_pos + 1 -> stk_pos;
		next_state -> state_stk[stk_pos]
	#)

	do
		1 -> stk_pos;
		0 -> state_stk[1];
		yylex -> look_ahead;

		SelectRule: (#
		do
			-1 -> apply_rule;
			(if state_stk[stk_pos]
@@for i, (state, table) in enumerate(zip(states, actions)):
			// @@{i} then
@@for item in state.items:
				(* @@{item} *)
@@end
@@if len(table) == 1:
@@for token, (action, value) in sorted(table.items()):
@@if action == 'SHIFT':
				@@{value} -> SHIFT;
				restart SelectRule
@@elif action == 'APPLY':
				@@{value} -> apply_rule
@@elif action == 'ERROR':
				'parse error' -> yyerror;
				1 -> result;
				leave SelectRule
@@continue
@@elif action == 'ACCEPT':
				0 -> result;
				leave SelectRule
@@continue
@@end
@@end
@@else:
				(if look_ahead
@@for token, (action, value) in sorted(table.items(), key = lambda pair: (pair[0] == -1, *pair)):
@@if token == -1:
				else
@@else:
				// @@{token} then (* @@{tokens[token] if token in tokens else chr(token)!r} *)
@@end
@@if action == 'SHIFT':
					@@{value} -> SHIFT;
					restart SelectRule
@@elif action == 'APPLY':
					@@{value} -> apply_rule
@@elif action == 'ERROR':
					'parse error' -> yyerror;
					1 -> result;
					leave SelectRule
@@continue
@@elif action == 'ACCEPT':
					0 -> result;
					leave SelectRule
@@continue
@@end
@@end
				if)
@@end
@@end
			if);
			(if apply_rule
@@for number, rule in enumerate(rules):
			// @@{number} then
				(* @@{' '.join(map(repr, rule.tokens)) if len(rule.tokens) != 0 else '%empty'} *)
@@if len(rule.tokens) != 0:
				stk_pos - @@{len(rule.tokens)} -> stk_pos;
@@end
@@if rule.action != "":
				(# do
@@{replace_placeholders(rule.action, 'yyval', 'value_stk[stk_pos+@@-1]')}
				#);
@@end
				@@{rule.production.value} -> REDUCE
@@end
			if);
			(if state_stk[stk_pos]
@@for i, (state, table) in enumerate(zip(states, gotos)):
@@if len(table) == 0:
@@continue
@@end
			// @@{i} then
@@for item in state.items:
				(* @@{item} *)
@@end
@@if len(table) == 1:
@@for token, entry in sorted(table.items()):
				@@{entry} -> GOTO
@@end
@@else:
				(if current
@@for token, entry in sorted(table.items(), key = lambda pair: (pair[0] == -1, *pair)):
@@if token == -1:
				else
@@else:
				// @@{token} then (* @@{tokens[token] if token in tokens else chr(token)!r} *)
@@end
				@@{entry} -> GOTO
@@end
				if)
@@end
@@end
			if);
			restart SelectRule
		#)
	exit result
	#);
@@{postamble}
