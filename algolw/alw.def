begin
	% This file is automatically generated %
@@{preamble}
@@for value, token in sorted(tokens.items()):
	integer @@{token.name.lstrip('_')};
@@end
	procedure yyinit;
	begin
@@for index, (value, token) in enumerate(sorted(tokens.items())):
		@@{token.name.lstrip('_')} := @@{token.value}@@{';' if index != len(tokens) - 1 else ''}
@@end
	end;

	integer procedure yyparse@@{'(' + globals['yyparse_parameters'] + ')' if 'yyparse_parameters' in globals else ''};
	begin
		integer yyparse_result;
		@@{globals['yystype']} array value_stk(0::127);
		integer array state_stk(0::127);
		integer stk_pos;

		integer look_ahead;

		@@{globals['yystype']} yyval;
		integer current;

		procedure shift_state(integer value state);
		begin
			value_stk(stk_pos) := yylval;
			stk_pos := stk_pos + 1;
			state_stk(stk_pos) := state;
			look_ahead := yylex@@{'(' + globals['yylex_arguments'] + ')' if 'yylex_arguments' in globals else ''};
			go to select
		end;

		procedure reduce(integer value type);
		begin
			current := type;
			go to shift
		end;

		procedure goto_state(integer value state);
		begin
			value_stk(stk_pos) := yyval;
			stk_pos := stk_pos + 1;
			state_stk(stk_pos) := state
		end;

		stk_pos := 0;

		state_stk(0) := 0;
		look_ahead := yylex@@{'(' + globals['yylex_arguments'] + ')' if 'yylex_arguments' in globals else ''};

	select:
		case state_stk(stk_pos) + 1 of
		begin
@@for i, (state, table) in enumerate(zip(states, actions)):
			% @@{i} %
			begin
@@for index, item in enumerate(state.items):
				% @@{str(item).replace(';', 'semicolon').replace('%', 'percent')} %
@@end
@@if len(table) == 1:
@@for token, (action, value) in sorted(table.items()):
@@if action == 'SHIFT':
				shift_state(@@{value})@@{';' if i != len(states) - 1 else ''}
@@elif action == 'APPLY':
				go to rule@@{value}@@{';' if i != len(states) - 1 else ''}
@@elif action == 'ERROR':
				yyerror("parse error");
				yyparse_result := 1;
				go to exit@@{';' if i != len(states) - 1 else ''}
@@continue
@@elif action == 'ACCEPT':
				yyparse_result := 0;
				go to exit@@{';' if i != len(states) - 1 else ''}
@@continue
@@end
@@end
@@else:
@@for index, (token, (action, value)) in enumerate(sorted(table.items(), key = lambda pair: (pair[0] == -1, *pair))):
@@if token == -1:
				else
@@else:
				@@{'if' if index == 0 else 'else if'} look_ahead = @@{token} then % @@{repr(tokens[token] if token in tokens else chr(token)).replace(';', 'semicolon').replace('%', 'percent')} %
@@end
@@if action == 'SHIFT':
					shift_state(@@{value})@@{';' if index == len(table) - 1 and i != len(states) - 1 else ''}
@@elif action == 'APPLY':
					go to rule@@{value}@@{';' if index == len(table) - 1 and i != len(states) - 1 else ''}
@@elif action == 'ERROR':
				begin
					yyerror("parse error");
					yyparse_result := 1;
					go to exit
				end@@{';' if index == len(table) - 1 and i != len(states) - 1 else ''}
@@elif action == 'ACCEPT':
				begin
					yyparse_result := 0;
					go to exit
				end@@{';' if index == len(table) - 1 and i != len(states) - 1 else ''}
@@end
@@end
@@end
			end@@{';' if i != len(states) - 1 else ''}
@@end
		end;
@@for number, rule in enumerate(rules):
rule@@{number}:
		% @@{' '.join(map(repr, rule.tokens)).replace(';', 'semicolon').replace('%', 'percent') if len(rule.tokens) != 0 else '$empty'} %
@@if len(rule.tokens) != 0:
		stk_pos := stk_pos - @@{len(rule.tokens)};
@@end
@@if rule.action != "":
		begin
@@{replace_placeholders(rule.action, 'yyval', 'value_stk(stk_pos+@@-1)')}
		end;
@@end
		reduce(@@{rule.production.value});
@@end
	shift:
		case state_stk(stk_pos) + 1 of
		begin
@@for i, (state, table) in enumerate(zip(states, gotos)):
			% @@{i} %
			begin
@@if len(table) == 0:
				go to select
			end@@{';' if i != len(states) - 1 else ''}
@@else:
@@for index, item in enumerate(state.items):
				% @@{str(item).replace(';', 'semicolon').replace('%', 'percent')} %
@@end
@@if len(table) == 1:
@@for token, entry in sorted(table.items()):
				goto_state(@@{entry});
				go to select
			end@@{';' if i != len(states) - 1 else ''}
@@end
@@else:
@@for index, (token, entry) in enumerate(sorted(table.items(), key = lambda pair: (pair[0] == -1, *pair))):
@@if token == -1:
				else
@@else:
				@@{'if' if index == 0 else 'else if'} current = @@{token} then % @@{repr(tokens[token] if token in tokens else chr(token)).replace(';', 'semicolon').replace('%', 'percent')} %
@@end
				begin
					goto_state(@@{entry});
					go to select
				end@@{';' if index == len(table) - 1 else ''}
@@end
@@if -1 not in table:
				go to select
@@end
			end@@{';' if i != len(states) - 1 else ''}
@@end
@@end
@@end
		end;
	exit:
		yyparse_result
	end;
@@{postamble}
end
