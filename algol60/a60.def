begin
	comment This file is automatically generated;
@@{preamble}
@@for value, token in sorted(tokens.items()):
	integer @@{token.name.replace('_', ' ')};
@@end
	procedure yyinit;
	begin
@@for index, (value, token) in enumerate(sorted(tokens.items())):
		@@{token.name.replace('_', ' ')} := @@{token.value}@@{';' if index != len(tokens) - 1 else ''}
@@end
	end;

	integer procedure yyparse@@{'(' + globals['yyparse_parameters'] + ')' if 'yyparse_parameters' in globals else ''};
@@if 'yyparse_parameter_declarations' in globals:
@@print(globals['yyparse_parameter_declarations'], file = file);
@@end
	begin
		@@{globals.get('yystype', 'integer')} array val stk[0:127];
		integer array state stk[0:127];
		integer stk pos;

		integer look ahead;

		@@{globals.get('yystype', 'integer')} yyval;
		integer current;

		procedure shift state(state);
			value state;
			integer state;
		begin
			val stk[stk pos] := yylval;
			stk pos := stk pos + 1;
			state stk[stk pos] := state;
			look ahead := yylex@@{'(' + globals['yylex_arguments'] + ')' if 'yylex_arguments' in globals else ''};
			go to select
		end;

		procedure reduce(type);
			value type;
			integer type;
		begin
			current := type;
			go to shift
		end;

		procedure gotostate(state);
			value state;
			integer state;
		begin
			val stk[stk pos] := yyval;
			stk pos := stk pos + 1;
			state stk[stk pos] := state
		end;

		stk pos := 0;

		state stk[0] := 0;
		look ahead := yylex@@{'(' + globals['yylex_arguments'] + ')' if 'yylex_arguments' in globals else ''};

	select:
		begin
			switch select state := @@{', '.join('state' + str(i) for i in range(len(states)))};
			go to select state[state stk[stk pos] + 1];

@@for i, (state, table) in enumerate(zip(states, actions)):
		state@@{i}:
@@for index, item in enumerate(state.items):
			@@{';' if index == 0 else ''}comment @@{str(item).replace(';', 'semicolon')};
@@end
@@if len(table) == 1:
@@for token, (action, value) in sorted(table.items()):
@@if action == 'SHIFT':
			shift state(@@{value})@@{';' if i != len(states) - 1 else ''}
@@elif action == 'APPLY':
			go to rule@@{value}@@{';' if i != len(states) - 1 else ''}
@@elif action == 'ERROR':
			yyerror("parse error");
			yyparse := 1;
			go to exit@@{';' if i != len(states) - 1 else ''}
@@continue
@@elif action == 'ACCEPT':
			yyparse := 0;
			go to exit@@{';' if i != len(states) - 1 else ''}
@@continue
@@end
@@end
@@else:
@@case_list = sorted(pair for pair in table.items() if pair[0] != -1)
@@for index, (token, (action, value)) in enumerate(case_list):
			@@{'if' if index == 0 else 'else if'} look ahead = @@{token} then
@@first_case = False
@@if action == 'SHIFT':
				shift state(@@{value})@@{';' if index == len(case_list) - 1 and -1 not in table and i != len(states) - 1 else ''}
@@elif action == 'APPLY':
				go to rule@@{value}@@{';' if index == len(case_list) - 1 and -1 not in table and i != len(states) - 1 else ''}
@@elif action == 'ERROR':
			begin
				yyerror("parse error");
				yyparse := 1;
				go to exit
			end@@{';' if index == len(case_list) - 1 and -1 not in table and i != len(states) - 1 else ''}
@@elif action == 'ACCEPT':
			begin
				yyparse := 0;
				go to exit
			end@@{';' if index == len(case_list) - 1 and -1 not in table and i != len(states) - 1 else ''}
@@end
@@end
@@if -1 in table:
@@(action, value) = table[-1]
			else
@@if action == 'SHIFT':
				shift state(@@{value})@@{';' if i != len(states) - 1 else ''}
@@elif action == 'APPLY':
				go to rule@@{value}@@{';' if i != len(states) - 1 else ''}
@@elif action == 'ERROR':
			begin
				yyerror("parse error");
				yyparse := 1;
				go to exit
			end@@{';' if i != len(states) - 1 else ''}
@@elif action == 'ACCEPT':
			begin
				yyparse := 0;
				go to exit
			end@@{';' if i != len(states) - 1 else ''}
@@end
@@end
@@end
@@end
	end;
@@for number, rule in enumerate(rules):
rule@@{number}:
	;comment @@{' '.join(map(repr, rule.tokens)).replace(';', 'semicolon') if len(rule.tokens) != 0 else '%empty'};
@@if len(rule.tokens) != 0:
	stk pos := stk pos - @@{len(rule.tokens)};
@@end
@@if rule.action != "":
	begin
@@{replace_placeholders(rule.action, 'yyval', 'val stk[stk pos+@@-1]')}
	end;
@@end
	reduce(@@{rule.production.value});
@@end
	shift:
		begin
			switch select state := @@{', '.join('state' + str(i) for i in range(len(states)))};
			go to select state[state stk[stk pos] + 1];
@@for i, (state, table) in enumerate(zip(states, gotos)):
		state@@{i}:
@@if len(table) == 0:
			go to select@@{';' if i != len(states) - 1 else ''}
@@continue
@@end
@@for index, item in enumerate(state.items):
			@@{';' if index == 0 else ''}comment @@{str(item).replace(';', 'semicolon')};
@@end
@@if len(table) == 1:
@@for token, entry in sorted(table.items()):
			gotostate(@@{entry});
			go to select@@{';' if i != len(states) - 1 else ''}
@@end
@@else:
@@first_case = True
@@case_list = sorted(pair for pair in table.items() if pair[0] != -1)
@@for index, (token, entry) in enumerate(case_list):
			@@{'if' if index == 0 else 'else if'} current = @@{token} then
@@first_case = False
			begin
				gotostate(@@{entry});
				go to select
			end@@{';' if index == len(case_list) - 1 and -1 not in table else ''}
@@end
@@if -1 in table:
@@entry = table[-1]
			else
			begin
				gotostate(@@{entry});
				go to select
			end@@{';' if i != len(states) - 1 else ''}
@@else:
			go to select@@{';' if i != len(states) - 1 else ''}
@@end
@@end
@@end
		end;
	exit:
	end;
@@{postamble}
end
