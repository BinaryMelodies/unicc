@@print("/* This file is automatically generated */", file = file)
@@{preamble}

@@for value, token in sorted(tokens.items()):
	declare @@{token.name} fixed value(@@{token.value});
@@end

	yyparse: procedure returns(fixed);
		declare
			value_stk(128) like yylval,
			state_stk(128) fixed,
			stk_pos fixed initial(1),
			look_ahead fixed,
			yyval like yylval,
			current fixed;

		SHIFT: procedure(state);
			declare state fixed;
			value_stk(stk_pos) = yylval;
			stk_pos = stk_pos + 1;
			state_stk(stk_pos) = state;
			look_ahead = yylex;
			go to select_state;
		end SHIFT;

		REDUCE: procedure(type);
			declare type fixed;
			current = type;
			go to shift_rule;
		end REDUCE;

		GOTO: procedure(state);
			declare state fixed;
			value_stk(stk_pos) = yyval;
			stk_pos = stk_pos + 1;
			state_stk(stk_pos) = state;
		end GOTO;

		state_stk(1) = 0;
		look_ahead = yylex();

	select_state:
		select(state_stk(stk_pos));
@@for i, (state, table) in enumerate(zip(states, actions)):
			when(@@{i}) do;
@@for item in state.items:
				/* @@{item} */
@@end
@@if len(table) == 1:
@@for token, (action, value) in sorted(table.items()):
@@if action == 'SHIFT':
				call SHIFT(@@{value});
@@elif action == 'APPLY':
				go to rule@@{value};
@@elif action == 'ERROR':
				call yyerror("parse error");
				return(1);
@@elif action == 'ACCEPT':
				return(0);
@@end
			end;
@@end
@@else:
				select(look_ahead);
@@for token, (action, value) in sorted(table.items()):
@@if token == -1:
@@continue
@@end
					when(@@{token}) do; /* @@{tokens[token] if token in tokens else chr(token)!r} */
@@if action == 'SHIFT':
						call SHIFT(@@{value});
@@elif action == 'APPLY':
						go to rule@@{value};
@@elif action == 'ERROR':
						call yyerror("parse error");
						return(1);
@@elif action == 'ACCEPT':
						return(0);
@@end
					end;
@@end
@@if -1 in table:
					otherwise do;
@@(action, value) = table[-1]
@@if action == 'SHIFT':
						call SHIFT(@@{value});
@@elif action == 'APPLY':
						go to rule@@{value};
@@elif action == 'ERROR':
						call yyerror("parse error");
						return(1);
@@elif action == 'ACCEPT':
						return(0);
@@end
					end;
@@end
				end;
			end;
@@end
@@end
		end;
@@end

@@for number, rule in enumerate(rules):
	rule@@{number}:
		/* @@{' '.join(map(repr, rule.tokens)) if len(rule.tokens) != 0 else '%empty'} */
@@if len(rule.tokens) != 0:
		stk_pos = stk_pos - @@{len(rule.tokens)};
@@end
@@if rule.action != "":
		do;
@@{replace_placeholders(rule.action, 'yyval', 'value_stk(stk_pos+@@-1)')}
		end;
@@end
		call REDUCE(@@{rule.production.value});
@@end

	shift_rule:
		select(state_stk(stk_pos));
@@for i, (state, table) in enumerate(zip(states, gotos)):
@@if len(table) == 0:
@@continue
@@end
			when(@@{i}) do;
@@for item in state.items:
				/* @@{item} */
@@end

@@if len(table) == 1:
@@for token, entry in sorted(table.items()):
				call GOTO(@@{entry});
@@end
@@else:
				select(current);
@@for token, entry in sorted(table.items()):
@@if token == -1:
@@continue
@@end
					when(@@{token}) /* @@{tokens[token] if token in tokens else chr(token)!r} */
						call GOTO(@@{entry});
@@end
@@if -1 in table:
@@entry = table[-1]
					otherwise
						call GOTO(@@{entry});
@@end
				end;
@@end
			end;
@@end
		end;
		go to select_state;
	end yyparse;

@@{postamble}
