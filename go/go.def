@@print("/* This file is automatically generated */", file = file)
@@{preamble}
const (
@@for value, token in sorted(tokens.items()):
@@{token.name} = @@{token.value}
@@end
)
func yyparse(@@{globals.get('yyparse_parameters', '')}) int {
	var value_stk [128] @@{globals.get('yystype', 'YYSTYPE')}
	var state_stk [128] int
	var stk_pos int

	var look_ahead int

	var yyval @@{globals.get('yystype', 'YYSTYPE')}
	var current int

	state_stk[0] = 0
	look_ahead = yylex(@@{globals.get('yylex_arguments', '')})

	for {
		switch state_stk[stk_pos] {
@@used_rules = set()
@@for i, (state, table) in enumerate(zip(states, actions)):
		case @@{i}:
@@for item in state.items:
			// @@{item}
@@end
@@if len(table) == 1:
@@for token, (action, value) in sorted(table.items()):
@@if action == 'SHIFT':
			value_stk[stk_pos] = yylval
			stk_pos ++
			state_stk[stk_pos] = @@{value}
			look_ahead = yylex(@@{globals.get('yylex_arguments', '')})
			continue
@@elif action == 'APPLY':
@@used_rules.add(value)
			goto rule@@{value}
@@elif action == 'ERROR':
			yyerror("parse error")
			return 1
@@continue
@@elif action == 'ACCEPT':
			return 0
@@continue
@@end
@@end
@@else:
			switch look_ahead {
@@for token, (action, value) in sorted(table.items()):
@@if token == -1:
			default:
@@else:
			case @@{token}: // @@{tokens[token] if token in tokens else chr(token)!r}
@@end
@@if action == 'SHIFT':
				value_stk[stk_pos] = yylval
				stk_pos ++
				state_stk[stk_pos] = @@{value}
				look_ahead = yylex(@@{globals.get('yylex_arguments', '')})
				continue
@@elif action == 'APPLY':
@@used_rules.add(value)
				goto rule@@{value}
@@elif action == 'ERROR':
				yyerror("parse error")
				return 1
@@continue
@@elif action == 'ACCEPT':
				return 0
@@continue
@@end
@@end
			}
@@end
			break
@@end
		}
@@for number, rule in enumerate(rules):
@@if number in used_rules:
	rule@@{number}:
		// @@{' '.join(map(repr, rule.tokens)) if len(rule.tokens) != 0 else '%empty'}
@@if len(rule.tokens) != 0:
		stk_pos -= @@{len(rule.tokens)}
@@end
@@if rule.action != "":
		{
@@{replace_placeholders(rule.action, 'yyval', 'value_stk[stk_pos+@@-1]')}
		}
@@end
		current = @@{rule.production.value}
		goto shift
@@end
@@end
	shift:
		switch state_stk[stk_pos] {
@@for i, (state, table) in enumerate(zip(states, gotos)):
@@if len(table) == 0:
@@continue
@@end
		case @@{i}:
@@for item in state.items:
			// @@{item}
@@end
@@if len(table) == 1:
@@for token, entry in sorted(table.items()):
			value_stk[stk_pos] = yyval
			stk_pos ++
			state_stk[stk_pos] = @@{entry}
			break
@@end
@@else:
			switch current {
@@for token, entry in sorted(table.items()):
@@if token == -1:
			default:
@@else:
			case @@{token}: // @@{tokens[token] if token in tokens else chr(token)!r}
@@end
				value_stk[stk_pos] = yyval
				stk_pos ++
				state_stk[stk_pos] = @@{entry}
				break
@@end
			}
			break
@@end
@@end
		}
	}
}
@@{postamble}
