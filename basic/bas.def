@@print("' This file is automatically generated", file = file)
@@{preamble}

Dim Shared YYLVAL As YYSTYPE

@@for value, token in sorted(tokens.items()):
@@if token.is_terminal():
Const @@{token.name} = @@{token.value}
@@end
@@end
Function yyparse(@@{globals.get('yyparse_parameters', '')}) As Integer
	Dim value_stk(128) As @@{globals.get('yystype', 'YYSTYPE')}
	Dim state_stk(128) As Integer
	Dim stk_pos As Integer
	Dim look_ahead As Integer
	Dim yyval As @@{globals.get('yystype', 'YYSTYPE')}
	Dim current As Integer

	stk_pos = 1

	state_stk(1) = 0
	look_ahead = yylex@@{'(' + globals['yylex_arguments'] + ')' if 'yylex_arguments' in globals else ''}

selection:
	Select Case state_stk(stk_pos)
@@for i, (state, table) in enumerate(zip(states, actions)):
		Case @@{i}
@@for item in state.items:
			' @@{item}
@@end
@@if len(table) == 1:
@@for token, (action, value) in sorted(table.items(), key = lambda pair: (pair[0] < 0, pair[0])):
@@if action == 'SHIFT':
			value_stk(stk_pos) = yylval
			stk_pos = stk_pos + 1
			state_stk(stk_pos) = @@{value}
			look_ahead = yylex@@{'(' + globals['yylex_arguments'] + ')' if 'yylex_arguments' in globals else ''}
			Goto selection
@@elif action == 'APPLY':
			Goto rule@@{value}
@@elif action == 'ERROR':
			yyerror "parse error"
			Return 1
@@continue
@@elif action == 'ACCEPT':
			Return 0
@@continue
@@end
@@end
@@else:
			Select Case look_ahead
@@for token, (action, value) in sorted(table.items(), key = lambda pair: (pair[0] < 0, pair[0])):
@@if token == -1:
				Case Else
@@else:
				Case @@{token}
					' @@{tokens[token] if token in tokens else chr(token)!r}
@@end
@@if action == 'SHIFT':
					value_stk(stk_pos) = yylval
					stk_pos = stk_pos + 1
					state_stk(stk_pos) = @@{value}
					look_ahead = yylex@@{'(' + globals['yylex_arguments'] + ')' if 'yylex_arguments' in globals else ''}
					Goto selection
@@elif action == 'APPLY':
					Goto rule@@{value}
@@elif action == 'ERROR':
					yyerror "parse error"
					Return 1
@@continue
@@elif action == 'ACCEPT':
					Return 0
@@continue
@@end
@@end
			End Select
@@end
@@end
	End Select
@@for number, rule in enumerate(rules):
rule@@{number}:
	' @@{' '.join(map(repr, rule.tokens)) if len(rule.tokens) != 0 else '%empty'}
@@if len(rule.tokens) != 0:
	stk_pos = stk_pos - @@{len(rule.tokens)}
@@end
@@if rule.action != "":
@@{replace_placeholders(rule.action, 'yyval', 'value_stk(stk_pos+@@-1)')}
@@end
	current = @@{rule.production.value}
	Goto shift
@@end
shift:
	Select Case state_stk(stk_pos)
@@for i, (state, table) in enumerate(zip(states, gotos)):
@@if len(table) == 0:
@@continue
@@end
		Case @@{i}
@@for item in state.items:
			' @@{item}
@@end
@@if len(table) == 1:
@@for token, entry in sorted(table.items(), key = lambda pair: (pair[0] < 0, pair[0])):
			value_stk(stk_pos) = yyval
			stk_pos = stk_pos + 1
			state_stk(stk_pos) = @@{entry}
@@end
@@else:
			Select Case current
@@for token, entry in sorted(table.items(), key = lambda pair: (pair[0] < 0, pair[0])):
@@if token == -1:
				Case Else
@@else:
				Case @@{token}
					' @@{tokens[token] if token in tokens else chr(token)!r}
@@end
					value_stk(stk_pos) = yyval
					stk_pos = stk_pos + 1
					state_stk(stk_pos) = @@{entry}
@@end
			End Select
@@end
@@end
	End Select
	Goto selection
End Function
@@{postamble}
